{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/phoenixc13/apse-mdc/APSE.schema.json",
  "title": "APSE 1.1 Model Description Contract",
  "description": "Machine-readable schema for all wire types in the APSE 1.1 ecosystem.",
  "version": "1.1.0",
  "definitions": {

    "AxonEvent": {
      "type": "object",
      "description": "Atomic event emitted by an AXON neuron.",
      "required": ["neuron_id", "magnitude", "tick_us"],
      "properties": {
        "neuron_id": {
          "type": "integer",
          "minimum": 0,
          "description": "Neuron index. Must be < n_features of parent AxonFrame."
        },
        "magnitude": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0,
          "description": "Activation magnitude. NaN is prohibited."
        },
        "tick_us": {
          "type": "integer",
          "minimum": 0,
          "description": "Microseconds since Unix epoch (UTC). Monotonic within a frame."
        }
      }
    },

    "AxonFrame": {
      "type": "object",
      "description": "Batch of events for a single hypothesis window.",
      "required": ["hypothesis", "events", "n_features"],
      "properties": {
        "hypothesis": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535,
          "description": "Hypothesis index. Must be < MAX_HYPOTHESES (65536)."
        },
        "events": {
          "type": "array",
          "items": { "$ref": "#/definitions/AxonEvent" },
          "maxItems": 4096,
          "description": "Events sorted by tick_us ascending."
        },
        "n_features": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16384,
          "description": "Feature space width. Consistent across session."
        }
      }
    },

    "EnablePacket": {
      "type": "object",
      "description": "Output packet sent from ENABLE to APEX after each forward pass.",
      "required": ["output", "shape", "iteration", "timestamp_ms"],
      "properties": {
        "output": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Flattened output tensor. Length == product(shape)."
        },
        "shape": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "minItems": 1,
          "description": "Shape of the output tensor."
        },
        "iteration": {
          "type": "integer",
          "minimum": 0,
          "description": "Monotonically increasing iteration number per session."
        },
        "timestamp_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Wall-clock UTC timestamp in milliseconds since Unix epoch."
        }
      }
    },

    "ApexFeedback": {
      "type": "object",
      "description": "Feedback signal sent from APEX back to AXON.",
      "required": ["session_id", "reward_signal", "prune_mask", "timestamp_ms"],
      "properties": {
        "session_id": {
          "type": "integer",
          "minimum": 0
        },
        "reward_signal": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0,
          "description": "Reinforcement/punishment signal."
        },
        "prune_mask": {
          "type": "array",
          "items": { "type": "boolean" },
          "description": "Hypotheses to deactivate. Length == active hypotheses in AXON."
        },
        "timestamp_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },

    "ApexDecision": {
      "type": "object",
      "description": "Decision made by APEX after processing an EnablePacket.",
      "required": ["session_id", "iteration", "action", "confidence", "timestamp_ms"],
      "properties": {
        "session_id":   { "type": "integer", "minimum": 0 },
        "iteration":    { "type": "integer", "minimum": 0 },
        "confidence":   { "type": "number",  "minimum": 0.0, "maximum": 1.0 },
        "timestamp_ms": { "type": "integer", "minimum": 0 },
        "action": {
          "type": "string",
          "enum": ["Forward", "Wait", "Terminate", "Feedback"],
          "description": "Action type."
        }
      }
    },

    "EnableConfig": {
      "type": "object",
      "description": "Configuration for the ENABLE engine.",
      "required": ["batch_size", "learning_rate", "device", "dtype"],
      "properties": {
        "max_iterations":  { "type": "integer", "minimum": 0 },
        "learning_rate":   { "type": "number",  "exclusiveMinimum": 0.0, "maximum": 1.0 },
        "batch_size":      { "type": "integer", "minimum": 1 },
        "device":          { "type": "string",  "enum": ["Cpu", "Cuda", "Metal"] },
        "dtype":           { "type": "string",  "enum": ["F32", "F16", "BF16", "I8", "Bool"] },
        "prune_threshold": { "type": "number",  "minimum": 0.0 }
      }
    }

  },

  "components": {
    "AXON": {
      "repository": "https://github.com/phoenixc13/axon-lang",
      "language": "Rust",
      "emits": ["AxonFrame"],
      "receives": ["ApexFeedback"]
    },
    "ENABLE": {
      "repository": "https://github.com/phoenixc13/enable-lib",
      "language": "Rust",
      "emits": ["EnablePacket"],
      "receives": ["AxonFrame"]
    },
    "APEX": {
      "repository": "https://github.com/phoenixc13/apex-middleware",
      "language": "Rust",
      "emits": ["ApexFeedback", "ApexDecision"],
      "receives": ["EnablePacket"]
    }
  },

  "constants": {
    "MAX_HYPOTHESES":      65536,
    "MAX_FEATURES":        16384,
    "MAX_EVENTS_PER_FRAME": 4096,
    "MAX_PACKET_QUEUE":    256,
    "CONFIDENCE_THRESHOLD": 0.85,
    "MAX_LOSS":            10.0,
    "FEEDBACK_INTERVAL":   10,
    "MAX_FRAME_BYTES":     4194304
  }
}
